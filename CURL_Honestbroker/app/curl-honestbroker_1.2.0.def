Bootstrap: docker
From: cudd2v/curl-honestbroker:1.2.0

%files
    # Copy the modified application.yml into the container.
    application.yml /app/application.yml

%environment
    export CURL_HONESTBROKER_BASE_DIRECTORY=/app

%runscript
    # Move into /app and run the client.
    cd /app && java -jar curl-honestbroker.jar --server.port=8050 --server.address=127.0.0.1